###############################################################################
# Скопируйте в .env и заполните:   cp .env.example .env && chmod 600 .env
###############################################################################

# ============================ ВАРИАНТ ДОСТУПА ================================

# --- Вариант A (рекомендуется): есть домен, автоматический HTTPS ---
# A-запись домена должна указывать на IP вашего VPS.
N8N_SITE_ADDRESS=n8n.example.com
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_SECURE_COOKIE=true

# --- Вариант B: домена нет, доступ по IP (трафик НЕ шифруется!) ---
# Закомментируйте блок выше, раскомментируйте этот и подставьте IP сервера:
# N8N_SITE_ADDRESS=:80
# N8N_HOST=203.0.113.10
# N8N_PROTOCOL=http
# WEBHOOK_URL=http://203.0.113.10/
# N8N_SECURE_COOKIE=false

# =============================== СЕКРЕТЫ =====================================

# Ключ шифрования сохранённых credentials. Сгенерировать: openssl rand -hex 32
# ВАЖНО: сохраните копию ключа. Потеряете ключ — потеряете все сохранённые
# в n8n пароли/токены интеграций.
N8N_ENCRYPTION_KEY=

# Пароль PostgreSQL. Сгенерировать: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_USER=n8n
POSTGRES_DB=n8n

# =============================== ПРОЧЕЕ ======================================

GENERIC_TIMEZONE=Asia/Tashkent

# Порты Caddy на хосте (менять только для локального теста, когда 80/443 заняты)
# HTTP_PORT=8080
# HTTPS_PORT=8443
