# Адрес берётся из .env (переменная N8N_SITE_ADDRESS):
#   вариант A: n8n.example.com -> Caddy сам выпустит и будет продлевать HTTPS-сертификат
#   вариант B: :80             -> доступ по http://IP-сервера (без шифрования)
{$N8N_SITE_ADDRESS}

# ── Свои сертификаты вместо автоматического Let's Encrypt (опционально) ──────
# Всё делает одна команда (копирует файлы, проверяет, включает, перезапускает):
#     bash setup.sh certs <домен> [/путь/fullchain.pem /путь/privkey.pem]
# Вручную: положите файлы в ./certs, раскомментируйте строку tls ниже
# и монтирование ./certs в docker-compose.yml.
#
# tls /certs/fullchain.pem /certs/privkey.pem

# ── Дополнительный пароль ПОВЕРХ входа n8n (опционально) ─────────────────────
# Встроенного логина n8n обычно достаточно. Если хотите второй рубеж:
#   1) сгенерируйте хеш:  docker compose exec caddy caddy hash-password
#   2) раскомментируйте блок ниже и вставьте хеш
#   3) примените:         docker compose restart caddy
# Вебхуки исключены из-под пароля, иначе внешние сервисы не смогут их вызывать.
#
# @ui {
#     not path /webhook* /rest/oauth2-credential/callback*
# }
# basic_auth @ui {
#     admin ВСТАВЬТЕ_СЮДА_ХЕШ
# }

reverse_proxy n8n:5678 {
    # не буферизовать ответы — нужно для live-обновлений в редакторе n8n
    flush_interval -1
}
